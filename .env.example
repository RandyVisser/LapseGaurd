# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: points at the Docker postgres container
# Production: use your Supabase direct connection string
#   Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:postgres@db:5432/lapseguard

# ── Supabase ──────────────────────────────────────────────────────────────────
# All four values are in Supabase → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # keep secret — never expose to frontend
SUPABASE_JWT_SECRET=your-jwt-secret               # Settings > API > JWT Secret

# ── Resend ────────────────────────────────────────────────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxx
# Must match a verified sending domain in Resend
# During setup: use onboarding@resend.dev for testing (Resend's shared test address)
FROM_EMAIL=alerts@yourdomain.com

# ── Internal cron auth ────────────────────────────────────────────────────────
# Any random secret — set same value in Railway cron service env vars
INTERNAL_API_KEY=change-me-in-production

# ── Frontend (Vite — baked in at build time) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Production: set to your Railway backend URL, e.g. https://lapseguard-backend.up.railway.app
# Local dev: leave unset — Vite proxy handles /api → backend:8000
VITE_API_URL=
VITE_HOA_ID=00000000-0000-0000-0000-000000000001
# Your dad's TypeForm URL — set once you have it
VITE_QUOTE_FORM_URL=https://form.typeform.com/to/your-form-id
# NOTE: VITE_TENANT_UNIT_ID is a dev-only shortcut (single hardcoded unit).
# Before going multi-tenant, replace with a DB lookup based on supabase_user_id.
VITE_TENANT_UNIT_ID=00000000-0000-0000-0000-000000000010
