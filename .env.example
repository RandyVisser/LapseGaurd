# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: points at the Docker postgres container
# Production: Supabase → Infrastructure → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:postgres@db:5432/lapseguard

# ── Supabase ──────────────────────────────────────────────────────────────────
# All from Supabase → Settings → General / API
#
# Key format note (Supabase updated their API key format):
#   Old format: eyJ... (JWT-shaped keys — no longer issued for new projects)
#   New format: sb_publishable_... and sb_secret_... (opaque keys)
#
# SUPABASE_URL        → Settings → General → Project URL
SUPABASE_URL=https://your-project.supabase.co
#
# SUPABASE_ANON_KEY   → Settings → API → Publishable key (sb_publishable_...)
#                       Safe to expose to browsers/clients
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx
#
# SUPABASE_SERVICE_ROLE_KEY → Settings → API → Secret key (sb_secret_...)
#                             NEVER expose this to the frontend or commit it
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx
#
# No JWT key env var needed — the backend fetches Supabase's public signing keys
# automatically from {SUPABASE_URL}/.well-known/jwks.json at startup.
# Key rotation is handled automatically.

# ── Anthropic ─────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys → Create Key
# Used by the dec page parser (Claude Haiku) to extract policy details
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend ────────────────────────────────────────────────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxx
# Must match a verified sending domain in Resend.
# No domain yet? Use onboarding@resend.dev (Resend's shared test address).
FROM_EMAIL=alerts@yourdomain.com
# Typeform quote URL — used in tenant notification emails
QUOTE_FORM_URL=https://form.typeform.com/to/your-form-id
# Public URL of the app — used in email links
APP_URL=https://www.condo.insure

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave unset (or set to blank) to allow all origins — fine for local dev.
# In production, set this to your frontend URL(s) to lock it down.
# Example: ALLOWED_ORIGINS=https://www.condo.insure,https://your-frontend.up.railway.app
ALLOWED_ORIGINS=

# ── Internal cron auth ────────────────────────────────────────────────────────
# Any strong random string — set the same value in the Railway cron service.
INTERNAL_API_KEY=change-me-in-production

# ── Stripe billing (flag-gated — everything stays dormant while unset) ────────
# BILLING_ENABLED=true turns on checkout/portal/webhook; leave unset to keep dark.
BILLING_ENABLED=
# dashboard.stripe.com → Developers → API keys → Secret key
# Use the sk_test_... key until the flow is verified end-to-end, then sk_live_...
STRIPE_SECRET_KEY=
# The recurring per-unit Price (quantity = unit count). Product catalog → price ID.
STRIPE_PRICE_ID=
# Developers → Webhooks → your endpoint → Signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Per-unit monthly rate in cents, display only (default $1.00/unit/mo)
UNIT_RATE_CENTS=100

# ── Frontend (Vite — baked into the bundle at build time) ─────────────────────
# VITE_SUPABASE_URL      → same as SUPABASE_URL above
VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY → same as SUPABASE_ANON_KEY (sb_publishable_...)
#                          This is safe to expose — it's the publishable key.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx
# VITE_API_URL           → Production: your Railway backend URL (no trailing slash)
#                          Local dev: leave blank — Vite proxy handles /api routing
VITE_API_URL=
VITE_HOA_ID=00000000-0000-0000-0000-000000000001
# Set once your dad sends the TypeForm URL.
VITE_QUOTE_FORM_URL=https://form.typeform.com/to/your-form-id
# NOTE: single hardcoded unit for dev/demo only.
# Multi-tenant fix needed before onboarding more than one tenant.
VITE_TENANT_UNIT_ID=00000000-0000-0000-0000-000000000010
# Must match backend BILLING_ENABLED. Reveals the Billing panel in admin
# settings and the trial banner on the dashboard. Remember: any new VITE_ var
# must also be declared ARG+ENV in frontend/Dockerfile.prod.
VITE_BILLING_ENABLED=
