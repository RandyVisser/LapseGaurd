# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/lapseguard

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret          # Settings > API > JWT Secret

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=alerts@yourdomain.com

# ── Internal cron auth ────────────────────────────────────────────────────────
INTERNAL_API_KEY=change-me-in-production

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_HOA_ID=00000000-0000-0000-0000-000000000001
VITE_QUOTE_FORM_URL=https://form.typeform.com/to/your-form-id
VITE_TENANT_UNIT_ID=00000000-0000-0000-0000-000000000010
